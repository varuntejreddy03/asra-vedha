generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  customer
  admin
}

enum ProductCategory {
  herbal_powders
  nutraceuticals
  superfoods
  immunity
  fitness
}

enum PaymentStatus {
  pending
  paid
  failed
}

enum OrderStatus {
  placed
  processing
  shipped
  delivered
  cancelled
}

enum CouponDiscountType {
  percentage
  fixed
}

enum EnquiryStatus {
  unread
  read
}

model User {
  id          String     @id @default(uuid())
  googleId    String?    @unique
  name        String
  email       String     @unique
  avatar      String?
  phone       String?
  role        Role       @default(customer)
  addresses   Address[]
  wishlist    Product[]  @relation("Wishlist")
  orders      Order[]
  couponUses  CouponUse[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Address {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  phone     String
  line1     String
  line2     String?
  city      String
  state     String
  pincode   String
  country   String   @default("India")
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Product {
  id              String           @id @default(uuid())
  slug            String           @unique
  name            String
  category        ProductCategory
  description     String
  benefitTagline  String
  price           Decimal          @db.Decimal(10, 2)
  comparePrice    Decimal?         @db.Decimal(10, 2)
  stock           Int              @default(0)
  image           String?
  benefits        Json
  ingredients     String
  howToUse        String?
  qualityBadges   String[]
  tags            String[]
  isOrganic       Boolean          @default(true)
  isPublished     Boolean          @default(true)
  isFeatured      Boolean          @default(false)
  metaTitle       String?
  metaDescription String?
  images          ProductImage[]
  weights         ProductWeight[]
  wishlistUsers   User[]           @relation("Wishlist")
  orderItems      OrderItem[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model ProductImage {
  id        String  @id @default(uuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  alt       String?
  sortOrder Int     @default(0)
}

model ProductWeight {
  id        String  @id @default(uuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  label     String
  price     Decimal @db.Decimal(10, 2)
  stock     Int     @default(0)
}

model Banner {
  id          String   @id @default(uuid())
  title       String
  subtitle    String?
  image       String?
  buttonText  String?
  buttonLink  String?
  position    String   @default("home")
  displayOrder Int     @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Coupon {
  id              String             @id @default(uuid())
  code            String             @unique
  discountType    CouponDiscountType
  value           Decimal            @db.Decimal(10, 2)
  minOrderValue   Decimal            @default(0) @db.Decimal(10, 2)
  maxDiscountCap  Decimal?           @db.Decimal(10, 2)
  totalUsageLimit Int?
  perUserLimit    Int?
  expiresAt       DateTime?
  isActive        Boolean            @default(true)
  uses            CouponUse[]
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
}

model CouponUse {
  id        String   @id @default(uuid())
  couponId  String
  coupon    Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  orderId   String?
  createdAt DateTime @default(now())
}

model Order {
  id                String        @id @default(uuid())
  userId            String?
  user              User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  orderNumber       String        @unique
  items             OrderItem[]
  shippingName      String
  shippingPhone     String
  shippingLine1     String
  shippingLine2     String?
  shippingCity      String
  shippingState     String
  shippingPincode   String
  couponCode        String?
  subtotal          Decimal       @db.Decimal(10, 2)
  discount          Decimal       @default(0) @db.Decimal(10, 2)
  shippingFee       Decimal       @default(0) @db.Decimal(10, 2)
  total             Decimal       @db.Decimal(10, 2)
  paymentStatus     PaymentStatus @default(pending)
  orderStatus       OrderStatus   @default(placed)
  razorpayOrderId   String?
  razorpayPaymentId String?
  trackingNumber    String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
}

model OrderItem {
  id        String   @id @default(uuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  name      String
  image     String?
  price     Decimal  @db.Decimal(10, 2)
  quantity  Int
  weight    String?
}

model BlogPost {
  id              String   @id @default(uuid())
  slug            String   @unique
  title           String
  category        String
  coverImage      String?
  excerpt         String
  content         String
  author          String   @default("ASRA VEDHA Team")
  tags            String[]
  metaTitle       String?
  metaDescription String?
  isPublished     Boolean  @default(false)
  publishedAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model ContactEnquiry {
  id        String        @id @default(uuid())
  name      String
  email     String
  phone     String?
  subject   String
  message   String
  status    EnquiryStatus @default(unread)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model DistributorEnquiry {
  id           String        @id @default(uuid())
  fullName     String
  companyName  String?
  country      String
  city         String
  phone        String
  email        String
  businessType String
  message      String
  status       EnquiryStatus @default(unread)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}
